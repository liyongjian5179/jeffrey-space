{
  "name": "jeffrey-space",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://hijeffrey.com",
  "description": "Jeffrey Li's personal digital space for SRE, AI Infra, writing, projects, and identity.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8765",
    "serve": "npm run preview",
    "build": "vite build && cp -R assets dist/assets && cp CNAME dist/CNAME",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "keywords": [
    "jeffrey",
    "jeffrey-space",
    "personal-site",
    "sre",
    "ai-infra",
    "design-system"
  ],
  "author": "Jeffrey Li",
  "license": "UNLICENSED",
  "type": "module",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "vite": "^7.0.0",
    "wrangler": "^4.110.0"
  }
}
